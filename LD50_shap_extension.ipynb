  {
   "cell_type": "markdown",
   "id": "sec8-3",
   "metadata": {},
   "source": [
    "## 8.3 Atom-Level Toxicity Heatmap\n",
    "\n",
    "This is the **centerpiece of Idea 1** — drawing molecules with atoms colored by their toxicity contribution.\n",
    "\n",
    "### How it works\n",
    "1. Compute Morgan fingerprints and record which atom is the *center* of each active bit (`bitInfo`)\n",
    "2. Get SHAP values for each bit for this specific molecule\n",
    "3. For each atom, sum the SHAP values of all bits it's a center of\n",
    "4. Map atom scores to a red (toxic contribution) ↔ blue (safe contribution) color scale\n",
    "5. Draw with RDKit"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "atom-heatmap-fn",
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_atom_shap_scores(smiles, shap_fp_values, radius=2, n_bits=2048):\n",
    "    \"\"\"\n",
    "    Map SHAP values from fingerprint bits back to individual atoms.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    smiles         : SMILES string for this molecule\n",
    "    shap_fp_values : 1D array of SHAP values for the 2048 fingerprint bits\n",
    "                     (i.e. shap_values[mol_idx, :2048] from our matrix)\n",
    "    radius, n_bits : must match what you used during featurization\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    mol            : RDKit Mol object\n",
    "    atom_scores    : dict {atom_idx: summed_shap_value}\n",
    "    \"\"\"\n",
    "    mol = Chem.MolFromSmiles(smiles)\n",
    "    if mol is None:\n",
    "        return None, {}\n",
    "\n",
    "    # bitInfo maps each active bit → list of (center_atom, radius) tuples\n",
    "    bit_info = {}\n",
    "    AllChem.GetMorganFingerprintAsBitVect(\n",
    "        mol, radius=radius, nBits=n_bits, bitInfo=bit_info\n",
    "    )\n",
    "\n",
    "    atom_scores = {atom.GetIdx(): 0.0 for atom in mol.GetAtoms()}\n",
    "\n",
    "    for bit_idx, environments in bit_info.items():\n",
    "        shap_val = shap_fp_values[bit_idx]\n",
    "        # Each environment is (center_atom, radius)\n",
    "        # We attribute the full SHAP value to the center atom\n",
    "        # (a more advanced version would spread it over the radius)\n",
    "        for center_atom, _radius in environments:\n",
    "            atom_scores[center_atom] += shap_val\n",
    "\n",
    "    return mol, atom_scores\n",
    "\n",
    "\n",
    "def shap_to_color(score, vmin, vmax):\n",
    "    \"\"\"\n",
    "    Map a SHAP score to an RGB tuple.\n",
    "    Negative (toxic) → red,  Positive (safe) → blue,  Zero → white.\n",
    "\n",
    "    We use a diverging white-centered scale so zero is always white\n",
    "    regardless of the range.\n",
    "    \"\"\"\n",
    "    if score < 0:  # toxic contribution: white → red\n",
    "        t = min(abs(score) / max(abs(vmin), 1e-9), 1.0)\n",
    "        return (1.0, 1.0 - 0.7*t, 1.0 - 0.7*t)  # RGB: red tint\n",
    "    else:          # safe contribution: white → blue\n",
    "        t = min(score / max(abs(vmax), 1e-9), 1.0)\n",
    "        return (1.0 - 0.7*t, 1.0 - 0.7*t, 1.0)  # RGB: blue tint\n",
    "\n",
    "\n",
    "def draw_molecule_shap(smiles, shap_fp_values, actual_y, pred_y,\n",
    "                       radius=2, n_bits=2048, img_size=(400, 300)):\n",
    "    \"\"\"\n",
    "    Draw a molecule with atoms colored by SHAP contribution.\n",
    "\n",
    "    Red atoms   = push prediction toward more toxic (lower log LD50)\n",
    "    Blue atoms  = push prediction toward less toxic (higher log LD50)\n",
    "    White atoms = neutral contribution\n",
    "\n",
    "    Returns a PIL Image.\n",
    "    \"\"\"\n",
    "    mol, atom_scores = get_atom_shap_scores(smiles, shap_fp_values, radius, n_bits)\n",
    "    if mol is None:\n",
    "        return None\n",
    "\n",
    "    scores = list(atom_scores.values())\n",
    "    vmin = min(scores) if min(scores) < 0 else -1e-9\n",
    "    vmax = max(scores) if max(scores) > 0 else  1e-9\n",
    "\n",
    "    atom_colors = {\n",
    "        idx: shap_to_color(score, vmin, vmax)\n",
    "        for idx, score in atom_scores.items()\n",
    "    }\n",
    "    atom_radii = {\n",
    "        idx: 0.4 + 0.4 * min(abs(score) / max(abs(vmin), abs(vmax), 1e-9), 1.0)\n",
    "        for idx, score in atom_scores.items()\n",
    "    }\n",
    "\n",
    "    # Draw with RDKit\n",
    "    drawer = rdMolDraw2D.MolDraw2DCairo(*img_size)\n",
    "    drawer.drawOptions().addAtomIndices = False\n",
    "    rdMolDraw2D.PrepareAndDrawMolecule(\n",
    "        drawer, mol,\n",
    "        highlightAtoms=list(atom_colors.keys()),\n",
    "        highlightAtomColors=atom_colors,\n",
    "        highlightAtomRadii=atom_radii,\n",
    "        highlightBonds=[],\n",
    "    )\n",
    "    drawer.FinishDrawing()\n",
    "\n",
    "    bio = io.BytesIO(drawer.GetDrawingText())\n",
    "    img = PILImage.open(bio).convert('RGB')\n",
    "\n",
    "    return img, atom_scores\n",
    "\n",
    "\n",
    "print('✅ Atom heatmap functions defined.')\n",
    "print('   Red  = this atom pushes prediction toward higher toxicity')\n",
    "print('   Blue = this atom pushes prediction toward lower toxicity')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec8-4",
   "metadata": {},
   "source": [
    "## 8.4 Visualize Individual Molecules\n",
    "\n",
    "Let's draw a grid of molecules — some toxic, some not — and see what the model highlights."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "draw-molecules",
   "metadata": {},
   "outputs": [],
   "source": [
    "y_pred_sample = xgb_model.predict(X_sample)\n",
    "\n",
    "def draw_grid(indices, title, ncols=3):\n",
    "    \"\"\"\n",
    "    Draw a grid of molecules with SHAP atom coloring.\n",
    "    indices: list of indices into the sample arrays\n",
    "    \"\"\"\n",
    "    nrows = (len(indices) + ncols - 1) // ncols\n",
    "    fig, axes = plt.subplots(nrows, ncols, figsize=(ncols*4, nrows*3.2))\n",
    "    axes = np.array(axes).flatten()\n",
    "\n",
    "    for ax_idx, mol_idx in enumerate(indices):\n",
    "        smiles = smiles_sample[mol_idx]\n",
    "        shap_fp = shap_values[mol_idx, :n_fp_bits]\n",
    "        actual  = y_sample[mol_idx]\n",
    "        pred    = y_pred_sample[mol_idx]\n",
    "\n",
    "        result = draw_molecule_shap(smiles, shap_fp, actual, pred)\n",
    "        if result is None or result[0] is None:\n",
    "            axes[ax_idx].axis('off')\n",
    "            continue\n",
    "\n",
    "        img, atom_scores = result\n",
    "        axes[ax_idx].imshow(img)\n",
    "        axes[ax_idx].axis('off')\n",
    "\n",
    "        # Color-coded title: red for toxic, green for non-toxic\n",
    "        color = '#C04828' if actual < 2.5 else '#3B6D11'\n",
    "        axes[ax_idx].set_title(\n",
    "            f'Actual: {actual:.2f}  Pred: {pred:.2f}',\n",
    "            fontsize=10, color=color, fontweight='bold'\n",
    "        )\n",
    "\n",
    "    # Hide unused axes\n",
    "    for ax_idx in range(len(indices), len(axes)):\n",
    "        axes[ax_idx].axis('off')\n",
    "\n",
    "    fig.suptitle(title, fontsize=13, fontweight='bold', y=1.01)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# --- Draw highly toxic molecules (actual log LD50 < 2.0) ---\n",
    "toxic_idx = np.where(y_sample < 2.0)[0][:6]\n",
    "print(f'Highly toxic molecules (log LD50 < 2.0): {len(toxic_idx)} found')\n",
    "if len(toxic_idx) >= 3:\n",
    "    draw_grid(toxic_idx[:6], 'Highly toxic molecules — red = toxic fragments')\n",
    "\n",
    "# --- Draw low-toxicity molecules (actual log LD50 > 4.5) ---\n",
    "safe_idx = np.where(y_sample > 4.5)[0][:6]\n",
    "print(f'\\nLow-toxicity molecules (log LD50 > 4.5): {len(safe_idx)} found')\n",
    "if len(safe_idx) >= 3:\n",
    "    draw_grid(safe_idx[:6], 'Low-toxicity molecules — blue = safe fragments')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec8-5",
   "metadata": {},
   "source": [
    "## 8.5 Find Recurring Toxic Substructures\n",
    "\n",
    "Which fingerprint bits have the most consistently **negative** SHAP values?  \n",
    "These are the structural patterns that the model associates with high toxicity.\n",
    "\n",
    "We then find an example molecule that activates each bit and draw it highlighted."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "toxic-bits",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Mean SHAP across all sample molecules, for fingerprint bits only\n",
    "fp_shap_mean = shap_values[:, :n_fp_bits].mean(axis=0)\n",
    "\n",
    "# Most toxic bits: most negative mean SHAP\n",
    "# (negative = pushes LD50 down = more toxic)\n",
    "toxic_bits   = np.argsort(fp_shap_mean)[:10]       # bottom 10\n",
    "safe_bits    = np.argsort(fp_shap_mean)[::-1][:10]  # top 10\n",
    "\n",
    "print('=== Top 10 most toxic fingerprint bits ===')\n",
    "print('(These substructures push predictions toward higher toxicity)\\n')\n",
    "\n",
    "for bit in toxic_bits:\n",
    "    mean_shap = fp_shap_mean[bit]\n",
    "    # How many molecules in the sample activate this bit?\n",
    "    n_active = (X_sample[:, bit] > 0).sum()\n",
    "    print(f'Bit {bit:4d}: mean SHAP = {mean_shap:.4f}  |  active in {n_active}/{N_SAMPLE} molecules')\n",
    "\n",
    "print('\\n=== Top 10 most safety-associated fingerprint bits ===')\n",
    "for bit in safe_bits:\n",
    "    mean_shap = fp_shap_mean[bit]\n",
    "    n_active = (X_sample[:, bit] > 0).sum()\n",
    "    print(f'Bit {bit:4d}: mean SHAP = +{mean_shap:.4f}  |  active in {n_active}/{N_SAMPLE} molecules')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "draw-toxic-bits",
   "metadata": {},
   "outputs": [],
   "source": [
    "def find_example_for_bit(bit_idx, X_data, smiles_data, n=3):\n",
    "    \"\"\"\n",
    "    Find n molecules that activate a specific fingerprint bit.\n",
    "    Returns list of (smiles, mol_sample_idx) tuples.\n",
    "    \"\"\"\n",
    "    active_mask = X_data[:, bit_idx] > 0\n",
    "    active_indices = np.where(active_mask)[0]\n",
    "    selected = active_indices[:n]\n",
    "    return [(smiles_data[i], i) for i in selected]\n",
    "\n",
    "\n",
    "print('Drawing example molecules for the 3 most toxic fingerprint bits...')\n",
    "print('(The highlighted atoms are the centers of the toxic substructure)\\n')\n",
    "\n",
    "for bit in toxic_bits[:3]:\n",
    "    examples = find_example_for_bit(bit, X_sample, smiles_sample, n=3)\n",
    "    if not examples:\n",
    "        continue\n",
    "\n",
    "    fig, axes = plt.subplots(1, len(examples), figsize=(len(examples)*4, 3.2))\n",
    "    if len(examples) == 1:\n",
    "        axes = [axes]\n",
    "\n",
    "    for ax, (smiles, mol_idx) in zip(axes, examples):\n",
    "        shap_fp = shap_values[mol_idx, :n_fp_bits]\n",
    "        actual  = y_sample[mol_idx]\n",
    "        pred    = y_pred_sample[mol_idx]\n",
    "\n",
    "        result = draw_molecule_shap(smiles, shap_fp, actual, pred)\n",
    "        if result is None or result[0] is None:\n",
    "            ax.axis('off')\n",
    "            continue\n",
    "\n",
    "        img, _ = result\n",
    "        ax.imshow(img)\n",
    "        ax.axis('off')\n",
    "        ax.set_title(f'log(LD50) = {actual:.2f}', fontsize=9)\n",
    "\n",
    "    fig.suptitle(\n",
    "        f'Bit {bit} — mean SHAP = {fp_shap_mean[bit]:.4f} (toxic pattern)\\n'\n",
    "        f'Red atoms = where this substructure is centered',\n",
    "        fontsize=10, fontweight='bold'\n",
    "    )\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec8-6",
   "metadata": {},
   "source": [
    "## 8.6 SHAP Waterfall Plot for a Single Molecule\n",
    "\n",
    "A waterfall plot shows step-by-step how each feature pushes the prediction  \n",
    "from the baseline (mean prediction) to the final prediction for ONE molecule.\n",
    "\n",
    "This is excellent for presentation: pick one interesting molecule and walk through it."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "waterfall",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Pick a molecule that's highly toxic and well-predicted\n",
    "# (ideally low actual LD50 AND low residual)\n",
    "residuals_sample = np.abs(y_sample - y_pred_sample)\n",
    "toxic_well_pred = np.where((y_sample < 2.5) & (residuals_sample < 0.4))[0]\n",
    "\n",
    "if len(toxic_well_pred) == 0:\n",
    "    mol_showcase_idx = np.argmin(y_sample)  # fallback: just most toxic\n",
    "else:\n",
    "    mol_showcase_idx = toxic_well_pred[0]\n",
    "\n",
    "showcase_smiles = smiles_sample[mol_showcase_idx]\n",
    "showcase_actual = y_sample[mol_showcase_idx]\n",
    "showcase_pred   = y_pred_sample[mol_showcase_idx]\n",
    "\n",
    "print(f'Showcase molecule:')\n",
    "print(f'  SMILES: {showcase_smiles}')\n",
    "print(f'  Actual log(LD50): {showcase_actual:.3f}')\n",
    "print(f'  Predicted:        {showcase_pred:.3f}')\n",
    "\n",
    "# SHAP Explanation object (needed for waterfall)\n",
    "# We use descriptor features only for readability (fewer than 2048 bits)\n",
    "explainer_desc = shap.TreeExplainer(xgb_model)\n",
    "shap_exp = explainer_desc(\n",
    "    X_sample[mol_showcase_idx:mol_showcase_idx+1]\n",
    ")\n",
    "\n",
    "# Waterfall for descriptor features only (slice indices n_fp_bits onward)\n",
    "shap_exp_desc_only = shap.Explanation(\n",
    "    values=shap_exp.values[0, n_fp_bits:],\n",
    "    base_values=shap_exp.base_values[0],\n",
    "    data=shap_exp.data[0, n_fp_bits:],\n",
    "    feature_names=DESCRIPTOR_NAMES\n",
    ")\n",
    "\n",
    "plt.figure(figsize=(9, 6))\n",
    "shap.waterfall_plot(shap_exp_desc_only, max_display=12, show=False)\n",
