    "This section is worth points and makes for a compelling presentation.\n",
    "\n",
    "### 7.1 Feature Importance (XGBoost)\n",
    "\n",
    "XGBoost tracks how often each feature is used to split data. High importance = the model relies on it heavily."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "feat_importance",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get XGBoost feature importances\n",
    "importances = xgb_model.feature_importances_\n",
    "n_features = X_train.shape[1]\n",
    "\n",
    "# Separate fingerprint bits from descriptors\n",
    "fp_importances   = importances[:n_fp_bits]\n",
    "desc_importances = importances[n_fp_bits:]\n",
    "\n",
    "# ---- Top descriptor features ----\n",
    "top_desc_idx = np.argsort(desc_importances)[::-1][:10]\n",
    "top_desc_names = [DESCRIPTOR_NAMES[i] for i in top_desc_idx]\n",
    "top_desc_vals  = desc_importances[top_desc_idx]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Descriptor importances\n",
    "axes[0].barh(top_desc_names[::-1], top_desc_vals[::-1], color='steelblue')\n",
    "axes[0].set_title('Top 10 Physicochemical Descriptors (XGBoost)', fontweight='bold')\n",
    "axes[0].set_xlabel('Feature Importance')\n",
    "\n",
    "# Fingerprint bit importance distribution\n",
    "axes[1].hist(fp_importances, bins=50, color='coral', edgecolor='white')\n",
    "axes[1].set_title('Morgan Fingerprint Bit Importance Distribution', fontweight='bold')\n",
    "axes[1].set_xlabel('Importance')\n",
    "axes[1].set_ylabel('Number of bits')\n",
    "axes[1].text(0.6, 0.8,\n",
    "    f'Most bits: ~0 importance\\nTop 50 bits carry most signal',\n",
    "    transform=axes[1].transAxes, fontsize=9, color='gray')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print('\\nInsight: The model relies heavily on a few key physicochemical descriptors')\n",
    "print('alongside sparse structural fingerprint patterns.')"
