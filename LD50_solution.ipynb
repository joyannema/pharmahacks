  {
   "cell_type": "markdown",
   "id": "sec2",
   "metadata": {},
   "source": [
    "---\n",
    "## 2. Molecular Featurization\n",
    "\n",
    "We convert each SMILES string into a **numeric feature vector** that ML models can learn from.\n",
    "\n",
    "We use two complementary feature types:\n",
    "\n",
    "### 2.1 Morgan Fingerprints (Structural)\n",
    "- Encodes **which chemical substructures** are present in a molecule\n",
    "- Represented as a 2048-bit binary vector\n",
    "- `radius=2` captures atom environments up to 2 bonds away (similar to ECFP4, widely used in drug discovery)\n",
    "\n",
    "### 2.2 RDKit Physicochemical Descriptors\n",
    "- Numerical properties like molecular weight, logP (lipophilicity), number of rings, H-bond donors/acceptors, etc.\n",
    "- These give the model **global, interpretable properties** of each molecule\n",
    "\n",
    "Together these give ~2250 features per molecule."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "featurize",
   "metadata": {},
   "outputs": [],
   "source": [
    "def smiles_to_morgan(smiles, radius=2, n_bits=2048):\n",
    "    \"\"\"\n",
    "    Convert a SMILES string to a Morgan fingerprint bit vector.\n",
    "    Returns a numpy array of 0s and 1s (length = n_bits).\n",
    "    Returns None if the SMILES is invalid.\n",
    "    \"\"\"\n",
    "    mol = Chem.MolFromSmiles(smiles)\n",
    "    if mol is None:\n",
    "        return None\n",
    "    fp = AllChem.GetMorganFingerprintAsBitVect(mol, radius=radius, nBits=n_bits)\n",
    "    arr = np.zeros((n_bits,), dtype=np.float32)\n",
    "    DataStructs.ConvertToNumpyArray(fp, arr)\n",
    "    return arr\n",
    "\n",
    "\n",
    "# A curated list of interpretable physicochemical descriptors\n",
    "DESCRIPTOR_NAMES = [\n",
    "    'MolWt',           # Molecular weight\n",
    "    'MolLogP',         # Lipophilicity (how well molecule dissolves in fat vs water)\n",
    "    'NumHDonors',      # Number of hydrogen bond donors\n",
    "    'NumHAcceptors',   # Number of hydrogen bond acceptors\n",
    "    'TPSA',            # Topological polar surface area — related to membrane permeability\n",
    "    'NumRotatableBonds',\n",
    "    'NumAromaticRings',\n",
    "    'NumAliphaticRings',\n",
    "    'RingCount',\n",
    "    'FractionCSP3',    # Fraction of sp3 carbons — relates to 3D complexity\n",
    "    'NumHeavyAtoms',\n",
    "    'NumHeteroatoms',  # Non-carbon, non-hydrogen atoms\n",
    "    'MaxPartialCharge',\n",
    "    'MinPartialCharge',\n",
    "    'BalabanJ',        # Topological index\n",
    "    'BertzCT',         # Molecular complexity\n",
    "    'Chi0v',           # Connectivity index\n",
    "    'Chi1v',\n",
    "    'Kappa1',          # Shape index\n",
    "    'Kappa2',\n",
    "    'Kappa3',\n",
    "]\n",
    "\n",
    "def smiles_to_descriptors(smiles):\n",
    "    \"\"\"\n",
    "    Compute physicochemical descriptors for a SMILES string.\n",
    "    Returns a numpy array of length len(DESCRIPTOR_NAMES).\n",
    "    \"\"\"\n",
    "    mol = Chem.MolFromSmiles(smiles)\n",
    "    if mol is None:\n",
    "        return np.full(len(DESCRIPTOR_NAMES), np.nan)\n",
    "    desc_funcs = dict(Descriptors.descList)\n",
    "    values = []\n",
    "    for name in DESCRIPTOR_NAMES:\n",
    "        try:\n",
    "            val = desc_funcs[name](mol)\n",
    "        except Exception:\n",
    "            val = np.nan\n",
    "        values.append(val)\n",
    "    return np.array(values, dtype=np.float32)\n",
    "\n",
    "\n",
    "def featurize_df(df, radius=2, n_bits=2048):\n",
    "    \"\"\"\n",
    "    Featurize a dataframe of SMILES into a combined feature matrix.\n",
    "    Combines Morgan fingerprints + physicochemical descriptors.\n",
    "    Also returns a mask of valid rows (some SMILES may fail to parse).\n",
    "    \"\"\"\n",
    "    smiles_list = df['Drug'].tolist()\n",
    "    fps, descs, valid_mask = [], [], []\n",
    "\n",
    "    for smi in smiles_list:\n",
    "        fp = smiles_to_morgan(smi, radius, n_bits)\n",
    "        d  = smiles_to_descriptors(smi)\n",
    "        if fp is not None:\n",
    "            fps.append(fp)\n",
    "            descs.append(d)\n",
    "            valid_mask.append(True)\n",
    "        else:\n",
    "            fps.append(np.zeros(n_bits, dtype=np.float32))\n",
    "            descs.append(np.full(len(DESCRIPTOR_NAMES), np.nan))\n",
    "            valid_mask.append(False)\n",
    "\n",
    "    X_fp   = np.stack(fps)\n",
    "    X_desc = np.stack(descs)\n",
    "\n",
    "    # Fill NaN in descriptors with column medians (computed later on train)\n",
    "    X_combined = np.concatenate([X_fp, X_desc], axis=1)\n",
    "    return X_combined, np.array(valid_mask)\n",
    "\n",
    "\n",
    "print('Featurizing train set...')\n",
    "X_train_raw, mask_train = featurize_df(train_df)\n",
    "print('Featurizing valid set...')\n",
    "X_valid_raw, mask_valid = featurize_df(valid_df)\n",
    "print('Featurizing test set...')\n",
    "X_test_raw,  mask_test  = featurize_df(test_df)\n",
    "\n",
    "y_train = train_df['Y'].values\n",
    "y_valid = valid_df['Y'].values\n",
    "y_test  = test_df['Y'].values\n",
    "\n",
    "print(f'\\nFeature matrix shape: {X_train_raw.shape}')\n",
    "print(f'  → {2048} Morgan fingerprint bits + {len(DESCRIPTOR_NAMES)} descriptors')\n",
    "print(f'Invalid SMILES in train: {(~mask_train).sum()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "impute",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Impute NaN values in descriptor columns using training set medians\n",
    "# (Important: compute medians on train only, apply to all sets — avoids data leakage)\n",
    "n_fp_bits = 2048\n",
    "desc_cols = slice(n_fp_bits, None)\n",
    "\n",
    "train_desc_medians = np.nanmedian(X_train_raw[:, desc_cols], axis=0)\n",
    "\n",
    "def impute_descriptors(X, medians):\n",
    "    X = X.copy()\n",
    "    desc = X[:, n_fp_bits:]\n",
    "    nan_mask = np.isnan(desc)\n",
    "    desc[nan_mask] = np.take(medians, np.where(nan_mask)[1])\n",
    "    X[:, n_fp_bits:] = desc\n",
    "    return X\n",
    "\n",
    "X_train = impute_descriptors(X_train_raw, train_desc_medians)\n",
    "X_valid = impute_descriptors(X_valid_raw, train_desc_medians)\n",
    "X_test  = impute_descriptors(X_test_raw,  train_desc_medians)\n",
    "\n",
    "print('✅ Featurization complete. No more NaNs:', not np.isnan(X_train).any())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec3",
   "metadata": {},
   "source": [
    "---\n",
    "## 3. Helper: Evaluation Function\n",
    "\n",
    "We wrap our three metrics into a single function for clean, consistent reporting."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eval_fn",
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate(model, X, y_true, split_name=''):\n",
    "    \"\"\"\n",
    "    Evaluate a trained model. Prints and returns R², MAE, RMSE.\n",
    "    \"\"\"\n",
    "    y_pred = model.predict(X)\n",
    "    r2   = r2_score(y_true, y_pred)\n",
    "    mae  = mean_absolute_error(y_true, y_pred)\n",
    "    rmse = np.sqrt(mean_squared_error(y_true, y_pred))\n",
    "    label = f'[{split_name}]' if split_name else ''\n",
    "    print(f'{label:10s}  R²={r2:.4f}  MAE={mae:.4f}  RMSE={rmse:.4f}')\n",
    "    return {'r2': r2, 'mae': mae, 'rmse': rmse, 'y_pred': y_pred}\n",
    "\n",
    "results = {}  # We'll store all model results here for final comparison"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec4",
   "metadata": {},
   "source": [
    "---\n",
    "## 4. Stage 1 — Baseline Models\n",
    "\n",
    "### 4.1 Ridge Regression\n",
    "The simplest possible linear baseline. Fast to train, gives us a floor to beat."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ridge",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.linear_model import Ridge\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.pipeline import Pipeline\n",
    "\n",
    "ridge = Pipeline([\n",
    "    ('scaler', StandardScaler()),\n",
    "    ('model',  Ridge(alpha=1.0))\n",
    "])\n",
    "ridge.fit(X_train, y_train)\n",
    "\n",
    "print('=== Ridge Regression ===')\n",
    "r_train = evaluate(ridge, X_train, y_train, 'Train')\n",
    "r_valid = evaluate(ridge, X_valid, y_valid, 'Valid')\n",
    "results['Ridge'] = r_valid"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec4b",
   "metadata": {},
   "source": [
    "### 4.2 Random Forest — Main Baseline\n",
    "\n",
    "Random Forest is an ensemble of decision trees. It handles the sparse fingerprint features well and doesn't require feature scaling."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "rf",
   "metadata": {},
   "outputs": [],
   "source": [
    "rf = RandomForestRegressor(\n",
    "    n_estimators=300,\n",
    "    max_depth=None,\n",
    "    min_samples_leaf=2,\n",
    "    n_jobs=-1,\n",
    "    random_state=42\n",
    ")\n",
    "rf.fit(X_train, y_train)\n",
    "\n",
    "print('=== Random Forest ===')\n",
    "rf_train = evaluate(rf, X_train, y_train, 'Train')\n",
    "rf_valid = evaluate(rf, X_valid, y_valid, 'Valid')\n",
    "results['RandomForest'] = rf_valid\n",
    "\n",
    "# Note: a big gap between Train R² and Valid R² would signal overfitting.\n",
    "gap = rf_train['r2'] - rf_valid['r2']\n",
    "print(f'\\nTrain–Valid R² gap: {gap:.4f}  (< 0.10 is acceptable)')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec5",
   "metadata": {},
   "source": [
    "---\n",
    "## 5. Stage 2 — Extended Models\n",
    "\n",
    "### 5.1 XGBoost\n",
    "\n",
    "XGBoost builds trees sequentially, each correcting the errors of the previous. Often the strongest single model on tabular data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "xgb_model",
   "metadata": {},
   "outputs": [],
   "source": [
    "xgb_model = xgb.XGBRegressor(\n",
    "    n_estimators=1000,\n",
    "    learning_rate=0.05,\n",
    "    max_depth=6,\n",
    "    subsample=0.8,\n",
    "    colsample_bytree=0.8,\n",
    "    reg_alpha=0.1,       # L1 regularization\n",
    "    reg_lambda=1.0,      # L2 regularization\n",
    "    early_stopping_rounds=50,\n",
    "    eval_metric='rmse',\n",
    "    random_state=42,\n",
    "    n_jobs=-1,\n",
    "    verbosity=0\n",
    ")\n",
    "\n",
    "xgb_model.fit(\n",
    "    X_train, y_train,\n",
    "    eval_set=[(X_valid, y_valid)],\n",
    "    verbose=False\n",
    ")\n",
    "\n",
    "print('=== XGBoost ===')\n",
    "xgb_train = evaluate(xgb_model, X_train, y_train, 'Train')\n",
    "xgb_valid = evaluate(xgb_model, X_valid, y_valid, 'Valid')\n",
    "results['XGBoost'] = xgb_valid\n",
    "print(f'Best iteration: {xgb_model.best_iteration}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec5b",
   "metadata": {},
   "source": [
    "### 5.2 Ensemble (Averaging RF + XGBoost predictions)\n",
    "\n",
    "Averaging predictions from diverse models often outperforms any single model, because their errors are partially uncorrelated."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ensemble",
   "metadata": {},
   "outputs": [],
   "source": [
    "class WeightedEnsemble:\n",
    "    \"\"\"Simple weighted average ensemble of trained models.\"\"\"\n",
    "    def __init__(self, models, weights=None):\n",
    "        self.models = models\n",
    "        self.weights = weights if weights else [1.0 / len(models)] * len(models)\n",
    "\n",
    "    def predict(self, X):\n",
    "        preds = np.stack([m.predict(X) for m in self.models], axis=1)\n",
    "        return np.average(preds, axis=1, weights=self.weights)\n",
    "\n",
    "# Try equal-weight ensemble first\n",
    "ensemble_eq = WeightedEnsemble([rf, xgb_model], weights=[0.5, 0.5])\n",
    "print('=== Ensemble (50/50 RF + XGB) ===')\n",
    "ens_train = evaluate(ensemble_eq, X_train, y_train, 'Train')\n",
    "ens_valid = evaluate(ensemble_eq, X_valid, y_valid, 'Valid')\n",
    "results['Ensemble_50_50'] = ens_valid\n",
    "\n",
    "# Tune weights: give more weight to whichever model is stronger on validation\n",
    "best_w, best_r2 = None, -np.inf\n",
    "for w in np.arange(0.1, 1.0, 0.1):\n",
    "    ens_tmp = WeightedEnsemble([rf, xgb_model], weights=[w, 1-w])\n",
    "    r2 = r2_score(y_valid, ens_tmp.predict(X_valid))\n",
    "    if r2 > best_r2:\n",
    "        best_r2, best_w = r2, w\n",
    "\n",
    "print(f'\\nBest RF weight: {best_w:.1f}, XGB weight: {1-best_w:.1f}')\n",
    "ensemble_best = WeightedEnsemble([rf, xgb_model], weights=[best_w, 1-best_w])\n",
    "print('=== Ensemble (Tuned Weights) ===')\n",
    "enst_train = evaluate(ensemble_best, X_train, y_train, 'Train')\n",
    "enst_valid = evaluate(ensemble_best, X_valid, y_valid, 'Valid')\n",
    "results['Ensemble_tuned'] = enst_valid"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec6",
   "metadata": {},
   "source": [
    "---\n",
    "## 6. Model Comparison\n",
    "\n",
    "Let's compare all models on the validation set side-by-side."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "comparison",
   "metadata": {},
   "outputs": [],
   "source": [
    "comparison_df = pd.DataFrame({\n",
    "    'Model': list(results.keys()),\n",
    "    'R²':    [v['r2']   for v in results.values()],\n",
    "    'MAE':   [v['mae']  for v in results.values()],\n",
    "    'RMSE':  [v['rmse'] for v in results.values()],\n",
    "}).sort_values('R²', ascending=False).reset_index(drop=True)\n",
    "\n",
    "print('=== Validation Set Comparison ===')\n",
    "print(comparison_df.to_string(index=False))\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n",
    "colors = ['#2196F3', '#4CAF50', '#FF9800', '#E91E63']\n",
    "for ax, metric in zip(axes, ['R²', 'MAE', 'RMSE']):\n",
